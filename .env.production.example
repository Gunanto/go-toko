# Docker image tags from GHCR
APP_IMAGE_TAG="main"
WEB_IMAGE_TAG="main"
EDGE_NETWORK="sims_edge"

APP_NAME="go-toko"
HTTP_ALLOWED_ORIGINS="https://gezy.my.id"

DB_NAME="gopos"
