# Docker image tags from GHCR
APP_IMAGE_TAG="main"
WEB_IMAGE_TAG="main"

# Bind only to localhost on the VPS.
# Put Nginx/Caddy/Traefik in front of this for public HTTPS access.
WEB_BIND="127.0.0.1:8080"

APP_NAME="go-toko"
HTTP_ALLOWED_ORIGINS="https://toko.example.com"

DB_NAME="gopos"
DB_USER="gopos"
DB_PASSWORD="replace-with-strong-db-password"

REDIS_PASSWORD=""

TOKEN_DURATION="15m"
TOKEN_KEY_HEX="replace-with-64-char-hex-secret"

# Optional Google OAuth for store customer login
STORE_GOOGLE_CLIENT_ID=""
STORE_GOOGLE_CLIENT_SECRET=""
STORE_GOOGLE_REDIRECT_URL="https://toko.example.com/v1/store/auth/google/callback"
STORE_GOOGLE_FRONTEND_REDIRECT="https://toko.example.com/store/auth/callback"
